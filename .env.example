# -----------------------------------------------------------------------------
# Supabase Postgres (Vercel) — Chilmund Payload CMS
# -----------------------------------------------------------------------------
# 1) In Supabase → SQL Editor, run: supabase/sql/01_create_payload_schema.sql
# 2) Use the pooled connection string for the app (Settings → Database).
#    Prefer "Session" pooler (or direct 5432) if you hit prepared-statement errors with Transaction pooler.
# 3) For `npm run db:migrate` / `db:migrate:create`, use a direct (non-pooler) URL if Supabase recommends it.
#
# Required — without this you get: "SASL: client password must be a string" (empty/missing password).
# Supabase → Project Settings → Database → Connection string → URI (use Session mode if Transaction pooler breaks Payload).
# If your DB password has special characters (@ # % / etc.), encode them (e.g. @ → %40) in the URI.
#
# Example (replace [password] with your real password):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
#
# Vercel: ETIMEDOUT to 104.x / 172.x (Cloudflare) on :5432 — you used the wrong host. Do NOT use the "Project URL"
# hostname (https://YOUR_REF.supabase.co). Copy the URI from Database settings; host must be db.YOUR_REF.supabase.co
# or *.pooler.supabase.com — never YOUR_REF.supabase.co alone.
#
# SSL: "self-signed certificate in certificate chain" — hosts matching *.supabase.com / *.supabase.co automatically
# use ssl.rejectUnauthorized=false (still encrypted; common on Windows). Supabase URIs often include sslmode=require;
# Chilmund strips those query params when applying relaxed TLS so node-pg does not override with strict verify-full.
# Opt in to strict CA checks: DATABASE_SSL_STRICT=true
# Non-Supabase DB with the same error: DATABASE_SSL_REJECT_UNAUTHORIZED=false

DATABASE_URL=

# Dedicated schema: Payload creates ONLY tables/enums here — nothing in `public`.
PAYLOAD_DATABASE_SCHEMA=chilmund_payload

# Optional pool tuning
# PAYLOAD_PG_POOL_MAX=10
# PAYLOAD_PG_IDLE_TIMEOUT_MS=30000

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Vercel: set build command to run migrations before Next build, e.g.:
#   npm run db:migrate && npm run build
# (Commit migration files from `npm run db:migrate:create` after your first local schema push.)
