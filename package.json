{
  "name": "chilmund",
  "version": "1.0.0",
  "description": "Chilmund Chemicals corporate website (Next.js + Payload CMS)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/next/dist/bin/next build --webpack",
    "vercel-build": "echo \"[chilmund] Running Payload migrations...\" && node ./node_modules/payload/bin.js migrate && echo \"[chilmund] Migrations done. Building Next.js...\" && node ./node_modules/next/dist/bin/next build --webpack",
    "postbuild": "node ./node_modules/next-sitemap/bin/next-sitemap.mjs --config next-sitemap.config.cjs",
    "dev": "node ./node_modules/next/dist/bin/next dev --webpack",
    "dev:prod": "node ./node_modules/next/dist/bin/next build && node ./node_modules/next/dist/bin/next start",
    "generate:importmap": "node ./node_modules/payload/bin.js generate:importmap",
    "generate:types": "node ./node_modules/payload/bin.js generate:types",
    "db:migrate": "node ./node_modules/payload/bin.js migrate",
    "db:migrate:create": "node ./node_modules/payload/bin.js migrate:create",
    "db:migrate:status": "node ./node_modules/payload/bin.js migrate:status",
    "ii": "pnpm --ignore-workspace install",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "payload": "node ./node_modules/payload/bin.js",
    "reinstall": "pnpm --ignore-workspace install",
    "start": "node ./node_modules/next/dist/bin/next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "node --import=tsx/esm ./node_modules/@playwright/test/cli.js test --config=playwright.config.ts",
    "test:int": "node ./node_modules/vitest/vitest.mjs run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.80.0",
    "@payloadcms/db-postgres": "^3.80.0",
    "@payloadcms/live-preview-react": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/plugin-form-builder": "3.80.0",
    "@payloadcms/plugin-nested-docs": "3.80.0",
    "@payloadcms/plugin-redirects": "3.80.0",
    "@payloadcms/plugin-search": "3.80.0",
    "@payloadcms/plugin-seo": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/ui": "3.80.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "16.2.1",
    "next-sitemap": "^4.2.3",
    "payload": "3.80.0",
    "pg": "^8.16.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.1",
    "jsdom": "28.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.9.0 <23",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
